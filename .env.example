APP_NAME=RIKMS
APP_ENV=local
APP_KEY=
APP_PREVIOUS_KEYS=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Manila
TRUSTED_PROXIES=
TRUSTED_HOSTS=
CORS_ALLOWED_ORIGINS=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
DOCUMENTS_DISK=documents
DOCUMENTS_ROOT=
RIKMS_MAX_DOCUMENT_UPLOAD_KB=25600
RIKMS_MAX_HIGHLIGHT_UPLOAD_KB=10240
RIKMS_DOCUMENT_PROCESSING_AUTO_QUEUE=true

# AI document assistance. Production defaults to Vertex. Ollama is restricted
# in code to local development and testing environments.
RIKMS_AI_ENABLED=false
RIKMS_AI_AUTO_QUEUE=true
RIKMS_AI_PROVIDER=vertex
RIKMS_AI_MODEL=gemini-3.1-flash-lite
GOOGLE_CLOUD_PROJECT=
VERTEX_AI_LOCATION=global
VERTEX_AI_MODEL=gemini-3.1-flash-lite
RIKMS_AI_PROMPT_VERSION=rikms-metadata-v1
RIKMS_AI_TIMEOUT_SECONDS=100
RIKMS_AI_MAX_TEXT_CHARACTERS=600000
RIKMS_AI_MIN_EMBEDDED_TEXT_CHARACTERS=500
LOCAL_PDF_TEXT_COMMAND=
LOCAL_PDF_RENDER_COMMAND=
LOCAL_OCR_COMMAND=
LOCAL_OCR_LANGUAGE=eng
LOCAL_OCR_MAX_PAGES=20
LOCAL_OCR_DPI=180
LOCAL_OCR_PAGE_TIMEOUT_SECONDS=15
DOCUMENTS_GCS_BUCKET=
DOCUMENT_AI_PROCESSOR_ID=
DOCUMENT_AI_LOCATION=us
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_NUM_CTX=8192
OLLAMA_MAX_INPUT_CHARACTERS=24000
OLLAMA_KEEP_ALIVE=30m

# Reserved integration boundary for the teammate-owned Drive mirror.
RIKMS_DRIVE_SYNC_ENABLED=false
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@rikms.gov.ph"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Security reports are private operational evidence. Generated reports belong
# under storage/app/security and must never be committed or publicly served.
SECURITY_REPORTS_DISK=security-reports
SECURITY_REPORTS_PREFIX=reports
SECURITY_REPORTS_PATH=
SECURITY_ALLOWED_TARGETS=http://127.0.0.1:8000,http://localhost:8000
SECURITY_PRODUCTION_HOST=rikms.v3ra.net
SECURITY_ACTIVE_SCAN_ENABLED=false

# Optional malware scanning. Production should require ClamAV before marking
# uploaded files as malware-cleared.
CLAMAV_ENABLED=false
CLAMAV_REQUIRED=false
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=10

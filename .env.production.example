APP_NAME=RIKMS
APP_ENV=production
APP_KEY=managed-by-secret-manager
APP_DEBUG=false
APP_URL=https://rikms.example.gov.ph
APP_TIMEZONE=Asia/Manila
TRUSTED_PROXIES=*
TRUSTED_HOSTS=^rikms\.example\.gov\.ph$,^localhost$,^127\.0\.0\.1$
CORS_ALLOWED_ORIGINS=https://rikms.example.gov.ph

LOG_CHANNEL=stderr
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
DB_PORT=5432
DB_DATABASE=rikms
DB_USERNAME=rikms_app
DB_PASSWORD=managed-by-secret-manager

SESSION_DRIVER=database
SESSION_LIFETIME=60
SESSION_EXPIRE_ON_CLOSE=true
SESSION_ENCRYPT=true
SESSION_COOKIE=rikms_session
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
CACHE_PREFIX=rikms_cache_
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local
DOCUMENTS_DISK=documents
DOCUMENTS_ROOT=/mnt/rikms-documents
RIKMS_MAX_DOCUMENT_UPLOAD_KB=25600
RIKMS_MAX_HIGHLIGHT_UPLOAD_KB=10240

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@rikms.example.gov.ph
MAIL_FROM_NAME=RIKMS

{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "rikms",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "typecheck": "tsc --noEmit",
        "lint": "eslint resources/js vite.config.js vitest.config.ts",
        "format": "prettier --write resources/js vite.config.js vitest.config.ts eslint.config.js",
        "format:check": "prettier --check resources/js vite.config.js vitest.config.ts eslint.config.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "check": "npm run format:check && npm run typecheck && npm run lint && npm run test && npm run build"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/vite": "^4.0.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^4.7.0",
        "concurrently": "^10.0.3",
        "eslint": "^10.7.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.7.0",
        "jsdom": "^29.1.1",
        "laravel-vite-plugin": "^2.0.0",
        "prettier": "^3.9.5",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.64.0",
        "vite": "^7.0.7",
        "vitest": "^4.1.10"
    },
    "dependencies": {
        "lucide-react": "^0.487.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-router": "^7.13.0",
        "recharts": "^2.15.2",
        "sonner": "^2.0.7",
        "tw-animate-css": "^1.4.0"
    }
}
